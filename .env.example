# Copy this file to .env and replace the placeholders with your Supabase project values.
# Do not commit .env to source control.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The server-side code reads these too.
SUPABASE_URL=${VITE_SUPABASE_URL}
SUPABASE_PUBLISHABLE_KEY=${VITE_SUPABASE_PUBLISHABLE_KEY}

# Optional: Supabase service role key for server-side operations.
# Use a secret key only in secure server environments, never in the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
